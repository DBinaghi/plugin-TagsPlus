#: views/admin/index/browse.php:196
msgid "Unused Tags"
msgstr "Etichette inutilizzate"

#: views/admin/index/browse.php:197
msgid "Delete all Tags not already associated with any record."
msgstr "Elimina tutte le etichette non ancora associate ad alcun record."

#: views/admin/index/browse.php:201
#: views/admin/index/browse.php:285
msgid "Delete all unused Tags? This cannot be undone."
msgstr "Eliminare tutte le etichette inutilizzate? Questa operazione non può essere annullata."

#: views/admin/index/browse.php:202
msgid "Delete Unused Tags"
msgstr "Elimina etichette inutilizzate"

#: views/admin/index/browse.php:210
msgid "Convert UPPERCASE/lowercase"
msgstr "Converti MAIUSCOLE/minuscole"

#: views/admin/index/browse.php:211
msgid "Modify all Tags, changing their case (Tags becoming identical after the transformation will be automatically merged)."
msgstr "Modifica tutte le etichette, cambiandone le maiuscole (le etichette che diventano identiche dopo la trasformazione verranno automaticamente fuse)."

#: views/admin/index/browse.php:216
msgid "Convert all Tags to UPPERCASE? Tags that become identical will be merged. This cannot be undone."
msgstr "Convertire tutte le etichette in MAIUSCOLO? Le etichette che diventano identiche verranno fuse. Questa operazione non può essere annullata."

#: views/admin/index/browse.php:217
msgid "ALL UPPERCASE"
msgstr "TUTTO MAIUSCOLO"

#: views/admin/index/browse.php:221
msgid "Convert all Tags to lowercase? Tags that become identical will be merged. This cannot be undone."
msgstr "Convertire tutte le etichette in minuscolo? Le etichette che diventano identiche verranno fuse. Questa operazione non può essere annullata."

#: views/admin/index/browse.php:222
msgid "all lowercase"
msgstr "tutto minuscolo"

#: views/admin/index/browse.php:226
msgid "Capitalize the first letters of all Tags? Tags that become identical will be merged. This cannot be undone."
msgstr "Portare in maiuscolo le iniziali di tutte le etichette? Le etichette che diventano identiche verranno fuse. Questa operazione non può essere annullata."

#: views/admin/index/browse.php:227
msgid "First Letters Uppercase"
msgstr "Iniziali Maiuscole"

#: views/admin/index/browse.php:233
msgid "Capitalize the first letter of all Tags? Tags that become identical will be merged. This cannot be undone."
msgstr "Portare in maiuscolo le iniziali di ogni frase? Le etichette che diventano identiche verranno fuse. Questa operazione non può essere annullata."

#: views/admin/index/browse.php:234
msgid "Sentences uppercase"
msgstr "Frasi maiuscole"

#: views/admin/index/browse.php:235
msgid "Subject to Tag"
msgstr "Da soggetto a etichetta"

#: views/admin/index/browse.php:236
msgid "Synchronize Tags with DC.Subject entries, creating Tags from subjects not yet present as Tags."
msgstr "Sincronizza le etichette con le voci DC.Subject, creando etichette dai soggetti non ancora presenti come etichette."

#: views/admin/index/browse.php:239
msgid "Synchronize Tags with DC.Subject entries? This cannot be undone."
msgstr "Sincronizzare le etichette con le voci DC.Subject? Questa operazione non può essere annullata."

#: views/admin/index/browse.php:240
msgid "Synchronize Tags"
msgstr "Sincronizza etichette"

