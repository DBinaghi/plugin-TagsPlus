#: views/admin/index/browse.php:7
msgid "Browse Tags"
msgstr "Foliumi etikedojn"

#: views/admin/index/browse.php:30 views/admin/index/browse.php:41
msgid "Editing Tags"
msgstr "Redakti etikedojn"

#: views/admin/index/browse.php:32 views/admin/index/browse.php:164
msgid "Similar Tags"
msgstr "Similaj etikedoj"

#: views/admin/index/browse.php:35 views/admin/index/browse.php:192
msgid "Tools"
msgstr "Iloj"

#: views/admin/index/browse.php:43
msgid "Search or browse all Tags used in the repository."
msgstr "Serĉu aŭ foliumu ĉiujn etikedojn uzatajn en la deponejo."

#: views/admin/index/browse.php:45
msgid "If needed, edit them"
msgstr "Se necese, redaktu ilin"

#: views/admin/index/browse.php:46 views/admin/index/browse.php:250
msgid "show editing instructions"
msgstr "montri redaktajn instrukciojn"

#: views/admin/index/browse.php:53
msgid "The number counts all records associated with a Tag. Filtering \"Record types\" to \"Items\" will provide links to all items containing the Tag."
msgstr "La nombro indikas ĉiujn dosierojn asociitajn al etikedo. Filtrante \"Dosierspecojn\" al \"Eroj\" aperos ligiloj al ĉiuj eroj enhavantaj la etikedon."

#: views/admin/index/browse.php:54
msgid "To edit the Tag name, click the name and begin editing, then press <strong>Enter</strong> to save or <strong>ESC</strong> to cancel. If the new name matches an existing Tag, you will be offered the option to merge them."
msgstr "Por redakti la nomon de etikedo, alklaku la nomon kaj komencu redakti, poste premu <strong>Enter</strong> por konservi aŭ <strong>ESC</strong> por nuligi. Se la nova nomo kongruas kun ekzistanta etikedo, vi ricevos la opcion kunfandi ilin."

#: views/admin/index/browse.php:55
msgid "To delete a Tag, click the X. Deleting a Tag will not delete the tagged records."
msgstr "Por forigi etikedon, alklaku la X. Forigi etikedon ne forigos la etikeditajn dosierojn."

#: views/admin/index/browse.php:61 views/admin/index/browse.php:62
msgid "Record Types"
msgstr "Dosierspecoj"

#: views/admin/index/browse.php:63
msgid "All"
msgstr "Ĉiuj"

#: views/admin/index/browse.php:76
msgid "Search..."
msgstr "Serĉi..."

#: views/admin/index/browse.php:85
msgid "Search Tags"
msgstr "Serĉi etikedojn"

#: views/admin/index/browse.php:88
msgid "Reset results"
msgstr "Restarigi rezultojn"

#: views/admin/index/browse.php:106
msgid "Name (A→Z)"
msgstr "Nomo (A→Z)"

#: views/admin/index/browse.php:107
msgid "Name (Z→A)"
msgstr "Nomo (Z→A)"

#: views/admin/index/browse.php:108
msgid "Count (high→low)"
msgstr "Kvanto (alta→malalta)"

#: views/admin/index/browse.php:109
msgid "Count (low→high)"
msgstr "Kvanto (malalta→alta)"

#: views/admin/index/browse.php:110
msgid "Date created (old→new)"
msgstr "Kreodato (malnova→nova)"

#: views/admin/index/browse.php:111
msgid "Date created (new→old)"
msgstr "Kreodato (nova→malnova)"

#: views/admin/index/browse.php:114 views/admin/index/browse.php:115
#: views/admin/index/browse.php:175
msgid "Results per page"
msgstr "Rezultoj per paĝo"

#: views/admin/index/browse.php:123 views/admin/index/browse.php:124
msgid "Sort by"
msgstr "Ordigi laŭ"

#: views/admin/index/browse.php:156
msgid "There are no tags to display. You must first tag some items."
msgstr "Neniuj etikedoj por montri. Vi devas unue etikedi kelkajn erojn."

#: views/admin/index/browse.php:166
msgid "Search similar Tags, sometime because of one or more typos, giving the chance to merge them."
msgstr "Serči similajn etikedojn, iufoje pro unu aŭ pli cimoj, donante eblecon kunfandi ilin."

#: views/admin/index/browse.php:169
msgid "Similarity threshold"
msgstr "Similectavolimo"

#: views/admin/index/browse.php:171
msgid "Strict"
msgstr "Strikta"

#: views/admin/index/browse.php:171
msgid "Moderate"
msgstr "Modera"

#: views/admin/index/browse.php:171
msgid "Permissive"
msgstr "Permesema"

#: views/admin/index/browse.php:181 views/admin/index/browse.php:273
msgid "Find Similar Tags"
msgstr "Trovi similajn etikedojn"

#: views/admin/index/browse.php:196
msgid "Unused Tags"
msgstr "Neuzataj etikedoj"

#: views/admin/index/browse.php:197
msgid "Delete all Tags not already associated with any record."
msgstr "Forigas ĉiujn etikedojn ne jam asociitajn al iu ajn dosiero."

#: views/admin/index/browse.php:201 views/admin/index/browse.php:285
msgid "Delete all unused Tags? This cannot be undone."
msgstr "Forigi ĉiujn neuzatajn etikedojn? Ĉi tio ne estas malfarebla."

#: views/admin/index/browse.php:202
msgid "Delete Unused Tags"
msgstr "Forigi neuzatajn etikedojn"

#: views/admin/index/browse.php:210
msgid "Convert UPPERCASE/lowercase"
msgstr "Konverti usklecon"

#: views/admin/index/browse.php:211
msgid "Modify all Tags, changing their case (Tags becoming identical after the transformation will be automatically merged)."
msgstr "Modifi ĉiujn etikedojn, ŝanĝante ilian usklon (etikedoj kiuj far iĝas identaj post la transformo estos aŭtomate kunfanditaj)."

#: views/admin/index/browse.php:216
msgid "Convert all Tags to UPPERCASE? Tags that become identical will be merged. This cannot be undone."
msgstr "Konverti ĉiujn etikedojn al MAJUSKLOJ? Etikedoj kiuj far iĝas identaj estos kunfanditaj. Ĉi tio ne estas malfarebla."

#: views/admin/index/browse.php:217
msgid "ALL UPPERCASE"
msgstr "ĈIO MAJUSKLE"

#: views/admin/index/browse.php:221
msgid "Convert all Tags to lowercase? Tags that become identical will be merged. This cannot be undone."
msgstr "Konverti ĉiujn etikedojn al minuskloj? Etikedoj kiuj far iĝas identaj estos kunfanditaj. Ĉi tio ne estas malfarebla."

#: views/admin/index/browse.php:222
msgid "all lowercase"
msgstr "ĉio minuskle"

#: views/admin/index/browse.php:226
msgid "Capitalize the first letters of all Tags? Tags that become identical will be merged. This cannot be undone."
msgstr "Ĉefliterigi ĉiujn etikedojn? Etikedoj kiuj fariĝas identaj estos kunfanditaj. Ĉi tio ne estas malfarebla."

#: views/admin/index/browse.php:227
msgid "First Letters Uppercase"
msgstr "Unuaj Literoj Majusklaj"

#: views/admin/index/browse.php:235
msgid "Subject to Tag"
msgstr "Temo al etikedo"

#: views/admin/index/browse.php:236
msgid "Synchronize Tags with DC.Subject entries, creating Tags from subjects not yet present as Tags."
msgstr "Sinkronigi etikedojn kun DC.Subject-eroj, kreante etikedojn el temoj ne jam ĉeestantaj kiel etikedoj."

#: views/admin/index/browse.php:239
msgid "Synchronize Tags with DC.Subject entries? This cannot be undone."
msgstr "Sinkronigi etikedojn kun DC.Subject-eroj? Ĉi tio ne estas malfarebla."

#: views/admin/index/browse.php:240
msgid "Synchronize Tags"
msgstr "Sinkronigi etikedojn"

#: views/admin/index/browse.php:251
msgid "hide editing instructions"
msgstr "kaŝi redaktajn instrukciojn"

#: views/admin/index/browse.php:255
msgid "%d Tag associations added."
msgstr "%d etikedaj asocioj aldonitaj."

#: views/admin/index/browse.php:256
msgid "No new Tag associations found."
msgstr "Neniuj novaj etikedaj asocioj trovitaj."

#: views/admin/index/browse.php:257
msgid "An error occurred during synchronization."
msgstr "Eraro okazis dum sinkronizado."

#: views/admin/index/browse.php:258
msgid "%d Tags modified."
msgstr "%d etikedoj modifitaj."

#: views/admin/index/browse.php:259
msgid "No Tags were modified."
msgstr "Neniu etikedo estis modifita."

#: views/admin/index/browse.php:260
msgid "An error occurred while changing Tag case."
msgstr "Eraro okazis dum ŝanĝo de usklo."

#: views/admin/index/browse.php:261
msgid "Processing..."
msgstr "Pritraktado..."

#: views/admin/index/browse.php:272
msgid "Searching..."
msgstr "Serĉado..."

#: views/admin/index/browse.php:274
msgid "No similar Tags couples found."
msgstr "Neniuj paroj de similaj etikedoj trovitaj."

#: views/admin/index/browse.php:275
msgid "%d similar Tags couples found."
msgstr "%d paroj de similaj etikedoj trovitaj."

#: views/admin/index/browse.php:276
msgid "Pagination"
msgstr "Paĝumado"

#: views/admin/index/browse.php:277
msgid "Page"
msgstr "Paĝo"

#: views/admin/index/browse.php:278
msgid "of"
msgstr "el"

#: views/admin/index/browse.php:279
msgid "Previous page"
msgstr "Antaŭa paĝo"

#: views/admin/index/browse.php:280
msgid "Next page"
msgstr "Sekva paĝo"

#: views/admin/index/browse.php:281
msgid "Keep left"
msgstr "Konservi maldekstran"

#: views/admin/index/browse.php:282
msgid "Keep right"
msgstr "Konservi dekstran"

#: views/admin/index/browse.php:283
msgid "The other Tag will be merged into \"%s\" and deleted. Proceed?"
msgstr "La alia etikedo estos kunfandita en \"%s\" kaj forigita. Ĉu daŭrigi?"

#: views/admin/index/browse.php:284
msgid "An error occurred during the merge."
msgstr "Eraro okazis dum kunfandado."

#: views/admin/index/browse.php:286
msgid "%d unused Tags deleted."
msgstr "%d neuzataj etikedoj forigitaj."

#: views/admin/index/browse.php:287
msgid "No unused Tags found."
msgstr "Neniuj neuzataj etikedoj trovitaj."

#: views/admin/index/browse.php:288
msgid "An error occurred while deleting unused Tags."
msgstr "Eraro okazis dum forigo de neuzataj etikedoj."

#: views/admin/index/browse.php:289
msgid "An error occurred during the rename."
msgstr "Eraro okazis dum alinomado."

#: views/admin/index/browse.php:290
msgid "An error occurred while searching for similar Tags."
msgstr "Eraro okazis dum serĉado de similaj etikedoj."

#: controllers/IndexController.php:21
msgid "Invalid tagType given."
msgstr "Nevalida etikedtipo donita."
